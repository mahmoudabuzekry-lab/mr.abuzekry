{
  "entities": {
    "BackupData": {
      "title": "BackupData",
      "description": "Full center backup data of students, groups, payments, attendance, and exam scores",
      "type": "object",
      "properties": {
        "students": { "type": "array" },
        "groups": { "type": "array" },
        "payments": { "type": "array" },
        "attendance": { "type": "array" },
        "exams": { "type": "array" },
        "examScores": { "type": "array" },
        "templates": { "type": "array" },
        "prices": { "type": "object" },
        "version": { "type": "string" },
        "exportedAt": { "type": "string" }
      }
    },
    "RealtimeCollection": {
      "title": "RealtimeCollection",
      "description": "Saves individual tables in real-time to allow synchronization across devices",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "updatedAt": { "type": "string" }
      }
    },
    "PublicRegistration": {
      "title": "PublicRegistration",
      "description": "Information provided by self-registering students pending teacher approval",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "parentPhone": { "type": "string" },
        "grade": { "type": "string" },
        "school": { "type": "string" },
        "address": { "type": "string" },
        "groupId": { "type": "string" },
        "exemptionType": { "type": "string" },
        "discountAmount": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "abuzekry_data/main_backup": {
      "schema": "BackupData",
      "description": "Single document backup of everything"
    },
    "abuzekry_realtime/{entityKey}": {
      "schema": "RealtimeCollection",
      "description": "Real-time list collections updated on-the-fly"
    },
    "abuzekry_public_registrations/{docId}": {
      "schema": "PublicRegistration",
      "description": "Public student registration records"
    }
  }
}
